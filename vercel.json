{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/server"
    },
    {
      "src": "/music/(.*)",
      "dest": "/api/server"
    },
    {
      "src": "/covers/(.*)",
      "dest": "/api/server"
    },
    {
      "src": "/health",
      "dest": "/api/server"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ],
  "env": {
    "NODE_ENV": "production",
    "DATA_DIR": "/tmp/qiaomu-data"
  }
}
